---
import PortfolioLayout from "../layouts/PortfolioLayout.astro";
import { projects, projectFilters } from "../data/projects";

const description =
  "Selected work by Luis Manzanero — web and mobile projects across React, Svelte, Vue, Flutter, Kotlin, Astro and more.";
---

<PortfolioLayout title="Projects" description={description}>
  <div class="page rise">
    <div class="prompt">$ ls ~/projects/</div>
    <h1 class="page-title font-display" style="font-size:clamp(36px,5.5vw,64px);margin-bottom:26px">
      Selected work
    </h1>

    <div class="filters">
      {
        projectFilters.map((f, i) => (
          <button class:list={["filter", "btnx", { active: i === 0 }]} data-filter={f}>
            {f}
          </button>
        ))
      }
    </div>

    <div class="project-grid" data-project-grid>
      {
        projects.map((p) => (
          <a
            class="project-card btnx"
            href={p.link}
            target="_blank"
            rel="noopener"
            data-project
            data-tag={p.tag}
          >
            <div class="project-thumb">
              {p.image ? (
                <img src={p.image} alt={p.name} loading="lazy" />
              ) : (
                <div class="placeholder">
                  <span class="font-display">{p.name[0]}</span>
                </div>
              )}
            </div>
            <div class="project-body">
              <div class="project-name">{p.name}</div>
              <div class="project-tag">#{p.tag}</div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</PortfolioLayout>

<script>
  function initFilters() {
    const grid = document.querySelector<HTMLElement>("[data-project-grid]");
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>("[data-project]"));
    const btns = Array.from(document.querySelectorAll<HTMLElement>("[data-filter]"));
    btns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const f = btn.dataset.filter;
        btns.forEach((b) => b.classList.toggle("active", b === btn));
        cards.forEach((c) => {
          c.style.display = f === "all" || c.dataset.tag === f ? "" : "none";
        });
      });
    });
  }
  document.addEventListener("astro:page-load", initFilters);
</script>
