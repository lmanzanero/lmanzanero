---
import PortfolioLayout from "../layouts/PortfolioLayout.astro";
import { resume } from "../data/resume";

const description =
  "Work history of Luis Manzanero — a self-taught full-stack web developer with a B.Sc. in Environmental Science, from Mohbel to Galen University.";
---

<PortfolioLayout title="Resume" description={description}>
  <div class="page rise">
    <h1 class="page-title font-display" style="font-size:clamp(36px,5.5vw,64px);margin-bottom:40px">
      Work history
    </h1>

    <ol class="timeline">
      {
        resume.map((job) => (
          <li class="timeline-item">
            <div class="job">
              <div class="job-head">
                <div class="job-co font-display">{job.co}</div>
                <div class="job-yr">{job.year}</div>
              </div>
              <div class="job-role">{job.role}</div>
              <div class="job-stack">{job.stack}</div>
              <p class="job-desc">{job.desc}</p>
              {job.link !== "#" && (
                <a class="job-link" href={job.link} target="_blank" rel="noopener">
                  {job.domain} ↗
                </a>
              )}
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</PortfolioLayout>
